{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "miaddon:hair_cut_sparks",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/particles"
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 25
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.1
      },
      "minecraft:emitter_shape_point": {},
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "math.random(0.8, 1.5)"
      },
      "minecraft:particle_initial_speed": "math.random(1.0, 2.5)",
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(-180, 180)",
        "rotation_rate": "math.random(-200, 200)"
      },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, -6, 0],
        "linear_drag_coefficient": 0.5
      },
      "minecraft:particle_appearance_billboard": {
        "size": ["0.08", "0.16 * (1 - variable.particle_age / variable.particle_lifetime)"],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 128,
          "texture_height": 128,
          "uv": [0, 0],
          "uv_size": [8, 8]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "variable.particle_age / variable.particle_lifetime",
          "gradient": {
            "0.0": "#6B3A2AFF",
            "0.3": "#8B5A3AEE",
            "0.7": "#D4B48388",
            "1.0": "#D4B48300"
          }
        }
      }
    }
  }
}
