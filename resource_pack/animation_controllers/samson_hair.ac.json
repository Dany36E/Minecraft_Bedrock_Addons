{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.samson.hair": {
      "initial_state": "hair_full",
      "states": {
        "hair_full": {
          "animations": ["samson.braids_sway"],
          "transitions": [
            { "cutting": "query.property('miaddon:hair_state') == 1" }
          ]
        },
        "cutting": {
          "animations": ["samson.hair_cut"],
          "transitions": [
            { "hair_gone": "query.all_animations_finished" }
          ]
        },
        "hair_gone": {
          "animations": ["samson.braids_hidden"],
          "transitions": [
            { "regrowing": "query.property('miaddon:hair_state') == 2" }
          ]
        },
        "regrowing": {
          "animations": ["samson.hair_regrow"],
          "transitions": [
            { "hair_full": "query.all_animations_finished" }
          ]
        }
      }
    }
  }
}