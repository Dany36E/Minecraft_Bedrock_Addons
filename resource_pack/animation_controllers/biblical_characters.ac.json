{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.biblical.base": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "animations": ["biblical.idle"],
          "transitions": [
            { "walking": "query.property('miaddon:anim_state') == 1" },
            { "sneaking": "query.property('miaddon:anim_state') == 2" }
          ]
        },
        "walking": {
          "animations": ["biblical.walk"],
          "transitions": [
            { "idle": "query.property('miaddon:anim_state') == 0" },
            { "sneaking": "query.property('miaddon:anim_state') == 2" }
          ]
        },
        "sneaking": {
          "animations": ["biblical.sneak"],
          "transitions": [
            { "idle": "query.property('miaddon:anim_state') == 0" },
            { "walking": "query.property('miaddon:anim_state') == 1" }
          ]
        }
      }
    }
  }
}
